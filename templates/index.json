              ]
            },
            "accordion_row_MT3rVE": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Q2. For Whom is Kurowear made for?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_RADXUH": {
                  "type": "text",
                  "settings": {
                    "text": "<p><strong>Ans:</strong> Kurowear is made for Indian Gen Z and millennials who want graphic tshirts with a strong point of view anime fans who want culturally coded designs, gym enthusiasts who want aggressive aesthetic wear, and people who appreciate dark and sarcastic humor in their clothing.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
