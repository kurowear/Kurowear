              "type": "_accordion-row",
              "settings": {
                "heading": "Q1. What is Kurowear?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_CXNDC7": {
                  "type": "text",
                  "settings": {
                    "text": "<p><strong>Ans:</strong> Kurowear is an Indian graphic t-shirt brand focused on three niches anime, gym culture, and dark humor. All designs are original and created in-house. Tshirts are oversized unisex fit, printed using DTF technology on 180 GSM and 240 GSM cotton, and available pan-India with COD.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
