                "custom_liquid_yebW6R": {
                  "type": "custom-liquid",
                  "name": "t:names.custom_liquid",
                  "settings": {
                    "custom_liquid": "{% liquid\n\n  assign ns_product = product\n\n  assign ns_variant = ns_product.selected_or_first_available_variant\n\n\n  assign ns_price = ns_variant.price\n\n  assign ns_compare = ns_variant.compare_at_price\n\n\n  assign ns_discount_percent = 0\n\n  if ns_compare > ns_price\n\n    assign ns_save = ns_compare | minus: ns_price\n\n    assign ns_discount_percent = ns_save | times: 100 | divided_by: ns_compare\n\n  endif\n\n%}\n\n\n{% if ns_product != blank and ns_variant != blank %}\n\n  <div class=\"ns-pdp-price-box\" data-ns-pdp-price>\n\n    <div class=\"ns-pdp-price-row\">\n\n      <span class=\"ns-pdp-main-price\" data-ns-price>\n\n        ₹{{ ns_price | money_without_currency | replace: '.00', '' }}\n\n      </span>\n\n\n      <span\n\n        class=\"ns-pdp-mrp\"\n\n        data-ns-mrp-wrap\n\n        {% unless ns_compare > ns_price %}\n\n          style=\"display: none;\"\n\n        {% endunless %}\n\n      >\n\n        MRP\n\n        <span data-ns-compare>\n\n          ₹{{ ns_compare | money_without_currency | replace: '.00', '' }}\n\n        </span>\n\n      </span>\n\n\n      <span\n\n        class=\"ns-pdp-discount\"\n\n        data-ns-discount\n\n        {% unless ns_compare > ns_price %}\n\n          style=\"display: none;\"\n\n        {% endunless %}\n\n      >\n\n        {{ ns_discount_percent }}% OFF\n\n      </span>\n\n\n      <span class=\"ns-pdp-tax\">\n\n        (Incl. of all taxes)\n\n      </span>\n\n    </div>\n\n\n    <div class=\"ns-pdp-upi-box\">\n\n      <div class=\"ns-pdp-upi-left\">\n\n        <span class=\"ns-pdp-upi-text\">\n\n          Extra\n\n        </span>\n\n\n        <span class=\"ns-pdp-upi-price\">\n\n          5% OFF\n\n        </span>\n\n\n        <span class=\"ns-pdp-upi-with\">\n\n          on prepaid orders\n\n        </span>\n\n      </div>\n\n\n      <div class=\"ns-pdp-upi-divider\"></div>\n\n\n      <div class=\"ns-pdp-upi-right\">\n\n        <img\n\n          class=\"ns-pdp-upi-icons\"\n\n          src=\"https://cdn.shopify.com/s/files/1/0758/4661/5256/files/UPI_Icon_FOPC_PDP_EXP.avif?v=1782452874\"\n\n          alt=\"UPI payment apps\"\n\n          loading=\"lazy\"\n\n        >\n\n\n        <img\n\n          class=\"ns-pdp-upi-logo\"\n\n          src=\"https://cdn.shopify.com/s/files/1/0758/4661/5256/files/UPI_Logo_nopadding_54e42ac1-1693-4bfa-b2df-f7b1aaf09dbb.webp?v=1782452883\"\n\n          alt=\"UPI\"\n\n          loading=\"lazy\"\n\n        >\n\n      </div>\n\n    </div>\n\n  </div>\n\n{% endif %}\n\n\n<script type=\"application/json\" data-ns-variant-json>\n\n  {{ product.variants | json }}\n\n</script>\n\n\n<style>\n\n  @import url('https://fonts.googleapis.com/css2?family=Mulish:wght@400;500;600;700;800&display=swap');\n\n\n  .ns-pdp-price-box,\n\n  .ns-pdp-price-box * {\n\n    box-sizing: border-box;\n\n    font-family: 'Mulish', sans-serif;\n\n  }\n\n\n  .ns-pdp-price-box {\n\n    width: 100%;\n\n    max-width: 590px;\n\n    background: #f6f8fc;\n\n    border: none;\n\n    border-radius: 0;\n\n    padding: 10px;\n\n    color: #080a12;\n\n  }\n\n\n  .ns-pdp-price-row {\n\n    display: flex;\n\n    align-items: center;\n\n    flex-wrap: wrap;\n\n    gap: 8px;\n\n    padding: 0 0 16px;\n\n    margin: 0;\n\n    border-bottom: 1px solid #d9dde6;\n\n  }\n\n\n  .ns-pdp-main-price {\n\n    color: #080a12;\n\n    font-size: 25px;\n\n    line-height: 1;\n\n    letter-spacing: -0.5px;\n\n    font-weight: 700;\n\n  }\n\n\n  .ns-pdp-mrp {\n\n    color: #9ca1aa;\n\n    font-size: 14px;\n\n    line-height: 1;\n\n    white-space: nowrap;\n\n    font-weight: 500;\n\n  }\n\n\n  .ns-pdp-mrp span {\n\n    color: #9ca1aa;\n\n    text-decoration: line-through;\n\n    text-decoration-thickness: 1px;\n\n  }\n\n\n  .ns-pdp-discount {\n\n    display: inline-flex;\n\n    align-items: center;\n\n    justify-content: center;\n\n    min-height: 26px;\n\n    padding: 6px 17px;\n\n    border-radius: 999px;\n\n    background: #f3e9ef;\n\n    color: #27242a;\n\n    font-size: 13px;\n\n    line-height: 1;\n\n    white-space: nowrap;\n\n    font-weight: 500;\n\n  }\n\n\n  .ns-pdp-tax {\n\n    color: #9ca1aa;\n\n    font-size: 13px;\n\n    line-height: 1;\n\n    white-space: nowrap;\n\n    font-weight: 500;\n\n  }\n\n\n  .ns-pdp-upi-box {\n\n    width: 100%;\n\n    min-height: 52px;\n\n    background: #f6f8fc;\n\n    border-radius: 0;\n\n    border-bottom: 2px solid #171a20;\n\n    display: flex;\n\n    align-items: center;\n\n    justify-content: space-between;\n\n    padding: 14px 0 12px;\n\n    gap: 12px;\n\n  }\n\n\n  .ns-pdp-upi-left {\n\n    display: flex;\n\n    align-items: center;\n\n    min-width: 0;\n\n    gap: 5px;\n\n    flex: 1;\n\n    flex-wrap: wrap;\n\n  }\n\n\n  .ns-pdp-upi-text,\n\n  .ns-pdp-upi-with {\n\n    color: #9ca1aa;\n\n    font-size: 13px;\n\n    line-height: 1;\n\n    white-space: nowrap;\n\n    font-weight: 500;\n\n  }\n\n\n  .ns-pdp-upi-price {\n\n    color: #ef7d16;\n\n    font-size: 14px;\n\n    line-height: 1;\n\n    white-space: nowrap;\n\n    font-weight: 600;\n\n  }\n\n\n  .ns-pdp-upi-divider {\n\n    width: 1px;\n\n    height: 28px;\n\n    background: #d9dde6;\n\n    flex: 0 0 1px;\n\n  }\n\n\n  .ns-pdp-upi-right {\n\n    display: flex;\n\n    align-items: center;\n\n    gap: 4px;\n\n    flex: 0 0 auto;\n\n  }\n\n\n  .ns-pdp-upi-icons {\n\n    width: 58px;\n\n    height: auto;\n\n    display: block;\n\n    object-fit: contain;\n\n  }\n\n\n  .ns-pdp-upi-logo {\n\n    width: 38px;\n\n    height: auto;\n\n    display: block;\n\n    object-fit: contain;\n\n  }\n\n\n  @media screen and (max-width: 749px) {\n\n    .ns-pdp-price-box {\n\n      max-width: 100%;\n\n    }\n\n\n    .ns-pdp-price-row {\n\n      gap: 7px;\n\n      padding-bottom: 14px;\n\n    }\n\n\n    .ns-pdp-main-price {\n\n      font-size: 22px;\n\n    }\n\n\n    .ns-pdp-mrp {\n\n      font-size: 13px;\n\n    }\n\n\n    .ns-pdp-discount {\n\n      min-height: 25px;\n\n      padding: 6px 14px;\n\n      font-size: 12px;\n\n    }\n\n\n    .ns-pdp-tax {\n\n      font-size: 12px;\n\n    }\n\n\n    .ns-pdp-upi-box {\n\n      min-height: 50px;\n\n      padding: 13px 0 11px;\n\n    }\n\n\n    .ns-pdp-upi-icons {\n\n      width: 54px;\n\n    }\n\n\n    .ns-pdp-upi-logo {\n\n      width: 34px;\n\n    }\n\n  }\n\n\n  @media screen and (max-width: 390px) {\n\n    .ns-pdp-main-price {\n\n      font-size: 20px;\n\n    }\n\n\n    .ns-pdp-tax {\n\n      width: 100%;\n\n      margin-top: 2px;\n\n    }\n\n\n    .ns-pdp-upi-text,\n\n    .ns-pdp-upi-with {\n\n      font-size: 12px;\n\n    }\n\n\n    .ns-pdp-upi-price {\n\n      font-size: 13px;\n\n    }\n\n\n    .ns-pdp-upi-icons {\n\n      width: 48px;\n\n    }\n\n\n    .ns-pdp-upi-logo {\n\n      width: 30px;\n\n    }\n\n  }\n\n</style>\n\n\n<script>\n\n  (function () {\n\n    var wrapper = document.querySelector('[data-ns-pdp-price]');\n\n    var jsonEl = document.querySelector('[data-ns-variant-json]');\n\n\n    if (!wrapper || !jsonEl) return;\n\n\n    var variants = [];\n\n\n    try {\n\n      variants = JSON.parse(jsonEl.textContent);\n\n    } catch (e) {\n\n      variants = [];\n\n    }\n\n\n    function formatRupee(cents) {\n\n      var amount = cents / 100;\n\n\n      try {\n\n        return '₹' + new Intl.NumberFormat('en-IN', {\n\n          maximumFractionDigits: 0\n\n        }).format(amount);\n\n      } catch (e) {\n\n        return '₹' + Math.round(amount);\n\n      }\n\n    }\n\n\n    function updatePrice(variant) {\n\n      if (!variant) return;\n\n\n      var price = variant.price;\n\n      var compare = variant.compare_at_price || 0;\n\n\n      var priceEl = wrapper.querySelector('[data-ns-price]');\n\n      var mrpWrap = wrapper.querySelector('[data-ns-mrp-wrap]');\n\n      var compareEl = wrapper.querySelector('[data-ns-compare]');\n\n      var discountEl = wrapper.querySelector('[data-ns-discount]');\n\n\n      if (priceEl) {\n\n        priceEl.textContent = formatRupee(price);\n\n      }\n\n\n      if (compare > price) {\n\n        if (mrpWrap) {\n\n          mrpWrap.style.display = '';\n\n        }\n\n\n        if (compareEl) {\n\n          compareEl.textContent = formatRupee(compare);\n\n        }\n\n\n        if (discountEl) {\n\n          var percent = Math.round(((compare - price) * 100) / compare);\n\n          discountEl.textContent = percent + '% OFF';\n\n          discountEl.style.display = 'inline-flex';\n\n        }\n\n      } else {\n\n        if (mrpWrap) {\n\n          mrpWrap.style.display = 'none';\n\n        }\n\n\n        if (discountEl) {\n\n          discountEl.style.display = 'none';\n\n        }\n\n      }\n\n    }\n\n\n    function getVariantFromUrl() {\n\n      var params = new URLSearchParams(window.location.search);\n\n      var variantId = params.get('variant');\n\n\n      if (!variantId) return null;\n\n\n      return variants.find(function (variant) {\n\n        return String(variant.id) === String(variantId);\n\n      });\n\n    }\n\n\n    function updateFromUrl() {\n\n      var variant = getVariantFromUrl();\n\n      if (variant) {\n\n        updatePrice(variant);\n\n      }\n\n    }\n\n\n    document.addEventListener('variant:change', function (event) {\n\n      if (event.detail && event.detail.variant) {\n\n        updatePrice(event.detail.variant);\n\n      }\n\n    });\n\n\n    document.addEventListener('change', function () {\n\n      setTimeout(updateFromUrl, 100);\n\n    });\n\n\n    window.addEventListener('popstate', updateFromUrl);\n\n\n    setTimeout(updateFromUrl, 300);\n\n  })();\n\n</script>"
