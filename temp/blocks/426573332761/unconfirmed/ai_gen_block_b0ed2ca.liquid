{% doc %}
  @prompt
    COD button banadena same jesa buy it now haina wesa
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cod-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-cod-button-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-cod-button-btn-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 15px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.font_size }}px;
    text-transform: {{ block.settings.text_case }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-cod-button-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_bg_color }};
    color: {{ block.settings.hover_text_color }};
    border-color: {{ block.settings.hover_border_color }};
  }

  .ai-cod-button-icon-{{ ai_gen_id }} {
    margin-right: 8px;
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-cod-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-cod-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cod-button-wrapper-{{ ai_gen_id }}">
    <button
      type="button"
      class="ai-cod-button-btn-{{ ai_gen_id }}"
      onclick="window.location.href='{{ block.settings.button_link }}'"
    >
      {% if block.settings.show_icon %}
        <svg
          class="ai-cod-button-icon-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
          <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
      {% endif %}
      {{ block.settings.button_label }}
    </button>
  </div>
</div>

{% schema %}
{
  "name": "COD button",
  "settings": [
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text",
      "default": "Cash on Delivery"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hover_bg_color",
      "label": "Hover background",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_border_color",
      "label": "Hover border",
      "default": "#e63946"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Font",
      "default": "inter_n7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    }
  ],
  "presets": [
    {
      "name": "COD button"
    }
  ]
}
{% endschema %}
