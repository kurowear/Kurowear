{%- comment -%}
  Snippet: snippets/schema-article.liquid
  Rendered from: layout/theme.liquid (just before </head>) — fires on all article templates
  Purpose:  BlogPosting JSON-LD + dynamic FAQPage JSON-LD for AI citation eligibility and rich results.
  Fires:    Article pages only.
  FAQ:      Automatically extracted from the article DOM when a "Frequently Asked Questions"
            heading is found. Supports h3+p and h2+p question/answer patterns.
{%- endcomment -%}

{%- if request.page_type == 'article' -%}
  {%- assign article_url = shop.url | append: article.url -%}
  {%- assign word_count = article.content | strip_html | split: ' ' | size -%}
  {%- assign reading_minutes = word_count | divided_by: 200 | plus: 1 -%}
  {%- assign org_id = shop.url | append: '#organization' -%}
  {%- assign logo_url = '' -%}
  {%- if settings.logo != blank -%}
    {%- capture logo_candidate -%}{{ settings.logo | image_url: width: 600 }}{%- endcapture -%}
    {%- if logo_candidate contains '//' and logo_candidate contains 'shopify' -%}
      {%- assign logo_url = logo_candidate | prepend: 'https:' -%}
    {%- endif -%}
  {%- endif -%}
  {%- assign article_locale = request.locale.iso_code | default: 'en' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": "{{ article_url }}#article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt_or_content | strip_html | truncate: 200 | json }},
  "url": "{{ article_url }}",
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "dateModified": "{{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "wordCount": {{ word_count }},
  "timeRequired": "PT{{ reading_minutes }}M",
  "inLanguage": {{ article_locale | json }},
  {%- if article.image -%}
  "image": {
    "@type": "ImageObject",
    "url": "{{ article.image | image_url: width: 1200 | prepend: 'https:' }}",
    "width": 1200,
    "height": 628
  },
  {%- endif -%}
  "author": {
    "@type": "{% if article.user.name != blank %}Person{% else %}Organization{% endif %}",
    "name": {% if article.user.name != blank %}{{ article.user.name | json }}{% else %}{{ shop.name | json }}{% endif %},
    "url": {% if article.user.homepage != blank %}{{ article.user.homepage | json }}{% else %}{{ shop.url | json }}{% endif %}
    {%- if article.user.name == blank %}, "@id": "{{ org_id }}"{%- endif -%}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "@id": "{{ org_id }}"
    {%- if logo_url != blank -%},
    "logo": {
      "@type": "ImageObject",
      "url": {{ logo_url | json }}
    }
    {%- endif -%}
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ article_url }}"
  },
  "isPartOf": {
    "@type": "Blog",
    "name": {{ blog.title | json }},
    "url": "{{ shop.url }}/blogs/{{ blog.handle }}"
  }
  {%- if article.tags.size > 0 -%},
  "keywords": {{ article.tags | join: ', ' | json }}
  {%- endif -%}
}
</script>

<script>
(function () {
  function extractAndInjectFAQSchema() {
    // Find the article body — toc-blog-template uses [data-tocb-body], article-template uses .rte
    var body = document.querySelector('[data-tocb-body]') || document.querySelector('.article__content .rte') || document.querySelector('.rte');
    if (!body) return;

    // Find the "Frequently Asked Questions" heading (h2 or h3, case-insensitive)
    var allHeadings = body.querySelectorAll('h2, h3');
    var faqHeading = null;
    for (var i = 0; i < allHeadings.length; i++) {
      if (/frequently\s+asked\s+questions/i.test(allHeadings[i].textContent)) {
        faqHeading = allHeadings[i];
        break;
      }
    }
    if (!faqHeading) return;

    // Walk siblings after the FAQ heading to collect Q&A pairs.
    // Questions are h3 (or h2 if the FAQ heading itself was h2 and questions are also h2).
    // Answers are p tags (or div/ul) immediately following a question heading.
    // Stop collecting when we hit another h2 (a new top-level section).
    var questionTag = faqHeading.tagName === 'H2' ? 'H3' : 'H3';
    var stopTag     = faqHeading.tagName === 'H2' ? 'H2' : 'H2';

    var pairs = [];
    var currentQuestion = null;
    var answerParts = [];

    function flushPair() {
      if (currentQuestion && answerParts.length) {
        pairs.push({ q: currentQuestion, a: answerParts.join(' ') });
      }
      currentQuestion = null;
      answerParts = [];
    }

    // Collect all direct children of body that follow the FAQ heading
    var allChildren = Array.prototype.slice.call(body.children);
    var faqIndex = allChildren.indexOf(faqHeading);
    if (faqIndex === -1) {
      // heading may be nested inside a wrapper div — fall back to nextElementSibling walk
      var el = faqHeading.nextElementSibling;
      while (el) {
        var tag = el.tagName;
        if (tag === stopTag && el !== faqHeading) { flushPair(); break; }
        if (tag === questionTag || tag === 'H4') {
          flushPair();
          currentQuestion = el.textContent.trim();
        } else if (currentQuestion && (tag === 'P' || tag === 'DIV' || tag === 'UL' || tag === 'OL')) {
          var txt = el.textContent.trim();
          if (txt) answerParts.push(txt);
        }
        el = el.nextElementSibling;
      }
      flushPair();
    } else {
      for (var j = faqIndex + 1; j < allChildren.length; j++) {
        var node = allChildren[j];
        var nt = node.tagName;
        if (nt === stopTag) { flushPair(); break; }
        if (nt === questionTag || nt === 'H4') {
          flushPair();
          currentQuestion = node.textContent.trim();
        } else if (currentQuestion && (nt === 'P' || nt === 'DIV' || nt === 'UL' || nt === 'OL')) {
          var t = node.textContent.trim();
          if (t) answerParts.push(t);
        }
      }
      flushPair();
    }

    if (!pairs.length) return;

    var articleUrl = {{ article_url | json }};
    var mainEntity = pairs.map(function (pair, idx) {
      return {
        "@type": "Question",
        "@id": articleUrl + "#faq-" + (idx + 1),
        "name": pair.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": pair.a.slice(0, 700)
        }
      };
    });

    var schema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "url": articleUrl,
      "mainEntity": mainEntity
    };

    var script = document.createElement('script');
    script.type = 'application/ld+json';
    script.textContent = JSON.stringify(schema);
    document.head.appendChild(script);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', extractAndInjectFAQSchema);
  } else {
    extractAndInjectFAQSchema();
  }
})();
</script>
{%- endif -%}
