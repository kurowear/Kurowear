{% liquid
  assign swatch_value = null
  assign extra_classes = ''

  case product_option_value.name
    when 'White'
      assign swatch_value = '#FFFFFF'
    when 'Black'
      assign swatch_value = '#000000'
    when 'Navy Blue'
      assign swatch_value = '#1B2A4A'
    when 'Bottle Green'
      assign swatch_value = '#1A3A2A'
    when 'Royal Blue'
      assign swatch_value = '#2B4CE0'
    when 'Maroon'
      assign swatch_value = '#800000'
    when 'Purple'
      assign swatch_value = '#6B21A8'
    when 'Petrol Blue'
      assign swatch_value = '#1B4F72'
    when 'Olive Green'
      assign swatch_value = '#556B2F'
    when 'Red'
      assign swatch_value = '#CC0000'
    when 'Golden Yellow'
      assign swatch_value = '#FFD700'
    when 'Light Baby Pink'
      assign swatch_value = '#FFB6C1'
    when 'Coral'
      assign swatch_value = '#FF6B6B'
    when 'Mint'
      assign swatch_value = '#98FF98'
    when 'Baby Blue'
      assign swatch_value = '#89CFF0'
    when 'Grey'
      assign swatch_value = '#808080'
    when 'Lavender'
      assign swatch_value = '#E6E6FA'
    when 'Yellow'
      assign swatch_value = '#FFE135'
    when 'Charcoal'
      assign swatch_value = '#36454F'
    when 'Mustard'
      assign swatch_value = '#FFDB58'
    when 'Pink'
      assign swatch_value = '#FFC0CB'
    when 'Dark Green'
      assign swatch_value = '#006400'
    when 'Rust'
      assign swatch_value = '#B7410E'
    when 'Sky Blue'
      assign swatch_value = '#87CEEB'
    when 'Teal'
      assign swatch_value = '#008080'
    when 'Dark Blue'
      assign swatch_value = '#00008B'
  endcase

  if swatch.color
    assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
  endif

  case mode
    when 'unscaled'
      assign extra_classes = extra_classes | append: ' swatch--unscaled'
    when 'filter'
      assign extra_classes = extra_classes | append: ' swatch--filter'
    when 'pill'
      assign extra_classes = extra_classes | append: ' swatch--pill'
  endcase
%}

<span
  class="swatch {{ extra_classes }}{% if swatch_value == null %} swatch--unavailable{% endif %}"
  style="--swatch-background: {{ swatch_value }};"
></span>

{%- if label != blank -%}
  <span class="visually-hidden">{{ label }}</span>
{%- endif -%}