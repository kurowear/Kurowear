{%- comment -%}
  Snippet: snippets/schema-breadcrumb.liquid
  Rendered from: layout/theme.liquid (before </head>)
  Purpose:  BreadcrumbList JSON-LD — mirrors the visual breadcrumb in snippets/breadcrumb.liquid.
  Fires:    On templates that show a breadcrumb (page, product, collection, blog, article).
            Skips homepage and cart (no breadcrumb shown there).
{%- endcomment -%}

{%- assign emit = false -%}
{%- if request.page_type == 'page'
    or request.page_type == 'product'
    or request.page_type == 'collection'
    or request.page_type == 'blog'
    or request.page_type == 'article' -%}
  {%- assign emit = true -%}
{%- endif -%}

{%- if emit -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}/"
    }
    {%- if request.page_type == 'page' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": "{{ shop.url }}{{ page.url }}"
    }
    {%- elsif request.page_type == 'product' -%}
      {%- if collection.url -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
      {%- else -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
      {%- endif -%}
    {%- elsif request.page_type == 'collection' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
    {%- elsif request.page_type == 'blog' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    }
    {%- elsif request.page_type == 'article' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "{{ shop.url }}{{ article.url }}"
    }
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
