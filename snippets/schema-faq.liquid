{%- comment -%}
  snippets/schema-faq.liquid
  Compatible with the Horizon FAQ section
{%- endcomment -%}

{%- assign first_question = true -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}

      {%- if block.type == 'accordion' -%}

        {%- for row in block.blocks -%}

          {%- assign answer = '' -%}

          {%- for child in row.blocks -%}
            {%- if child.type == 'text' -%}
              {%- assign answer = child.settings.text | strip_html | strip_newlines | strip -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if row.settings.heading != blank and answer != blank -%}

            {%- unless first_question -%},{%- endunless -%}

            {
              "@type": "Question",
              "@id": "{{ canonical_url }}#faq-{{ row.id }}",
              "name": {{ row.settings.heading | strip_html | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ answer | truncate: 1000 | json }}
              }
            }

            {%- assign first_question = false -%}

          {%- endif -%}

        {%- endfor -%}

      {%- endif -%}

    {%- endfor -%}
  ]
}
</script>