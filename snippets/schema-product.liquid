{%- comment -%}
  Snippet: snippets/schema-product.liquid
  Rendered from: layout/theme.liquid (just before </head>) — fires on all product templates
  Purpose:  Product + Offer/AggregateOffer + ShippingDetails + ReturnPolicy JSON-LD.
  Fires:    Product pages only.

  Strategy:
    - Single-variant products: emit a single "Offer".
    - Multi-variant products:  emit an "AggregateOffer" with priceRange + offerCount
      (Google's recommended pattern for high-variant products). This avoids hitting
      Liquid's per-snippet output limit on products with many variants while keeping
      the full set of merchant-listing properties (shipping, returns, currency,
      validity, condition, seller).

  Reviews:  AggregateRating reads from Judge.me's standard Shopify metafields:
              product.metafields.reviews.rating       (compound rating type)
              product.metafields.reviews.rating_count (integer)
            Enable "Save metafields" in Judge.me app settings to populate these.
            Block is omitted automatically when no reviews exist (avoids invalid rating: 0).

  Shipping + return policy values reflect US store policy. Update applicableCountry,
  shippingDestination, and merchantReturnDays here if policy changes.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  {%- assign product_url = shop.url | append: product.url -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign brand_name = product.vendor | default: shop.name -%}
  {%- assign org_id = shop.url | append: '#organization' -%}
  {%- assign currency_code = cart.currency.iso_code | default: shop.currency -%}
  {%- assign price_valid_until = 'now' | date: '%Y' | plus: 1 | append: '-12-31' -%}
  {%- if product.available -%}
    {%- assign availability_url = 'https://schema.org/InStock' -%}
  {%- else -%}
    {%- assign availability_url = 'https://schema.org/OutOfStock' -%}
  {%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ product_url }}#product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": "{{ product_url }}",
  {%- if current_variant.sku != blank -%}"sku": {{ current_variant.sku | json }},{%- endif -%}
  {%- if current_variant.barcode != blank -%}
    {%- assign barcode_size = current_variant.barcode | size -%}
    {%- if barcode_size == 13 or barcode_size == 12 or barcode_size == 14 or barcode_size == 8 -%}
      "gtin": {{ current_variant.barcode | json }},
    {%- else -%}
      "mpn": {{ current_variant.barcode | json }},
    {%- endif -%}
  {%- endif -%}
  "brand": { "@type": "Brand", "name": {{ brand_name | json }} },
  "image": [
    {%- for image in product.images limit: 5 -%}
      "{{ image | image_url: width: 1200 | prepend: 'https:' }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  {%- if product.type != blank -%}"category": {{ product.type | json }},{%- endif -%}
  {%- if product.metafields.custom.metal_type != blank -%}"material": {{ product.metafields.custom.metal_type | json }},{%- endif -%}
  {%- if product.metafields.custom.color != blank -%}"color": {{ product.metafields.custom.color | json }},{%- endif -%}
  {%- if product.metafields.custom.gemstone != blank -%}"gemstone": {{ product.metafields.custom.gemstone | json }},{%- endif -%}
  {%- assign jm_rating_meta = product.metafields.reviews.rating.value -%}
  {%- assign jm_rating_count = product.metafields.reviews.rating_count.value | default: product.metafields.reviews.rating_count -%}
  {%- if jm_rating_meta != blank and jm_rating_count != blank and jm_rating_count > 0 -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ jm_rating_meta.value | default: jm_rating_meta }},
    "reviewCount": {{ jm_rating_count }},
    "bestRating": {{ jm_rating_meta.scale_max | default: 5 }},
    "worstRating": {{ jm_rating_meta.scale_min | default: 1 }}
  },
  {%- endif -%}
  "offers": {
    {%- if product.variants.size > 1 -%}
    "@type": "AggregateOffer",
    "url": "{{ product_url }}",
    "priceCurrency": "{{ currency_code }}",
    "lowPrice": {{ product.price_min | divided_by: 100.0 }},
    "highPrice": {{ product.price_max | divided_by: 100.0 }},
    "offerCount": {{ product.variants.size }},
    {%- else -%}
    "@type": "Offer",
    "url": "{{ product_url }}",
    "priceCurrency": "{{ currency_code }}",
    "price": {{ current_variant.price | divided_by: 100.0 }},
    {%- endif -%}
    "priceValidUntil": "{{ price_valid_until }}",
    "availability": "{{ availability_url }}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }}, "@id": "{{ org_id }}" },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": 0, "currency": "{{ currency_code }}" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 10, "maxValue": 12, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue":20 , "maxValue": 25, "unitCode": "DAY" }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  }
}
</script>
{%- endif -%}
