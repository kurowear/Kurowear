{%- comment -%}
  snippets/schema-faq.liquid
  FAQPage Schema for FAQ section
{%- endcomment -%}

{%- assign first_item = true -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}

      {%- if block.settings.heading != blank and block.settings.text != blank -%}

        {%- unless first_item -%},{%- endunless -%}
        {
          "@type": "Question",
          "@id": "{{ canonical_url }}#faq-{{ block.id }}",
          "name": {{ block.settings.heading | strip_html | strip_newlines | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.text | strip_html | strip_newlines | json }}
          }
        }
        {%- assign first_item = false -%}

      {%- endif -%}

    {%- endfor -%}
  ]
}
</script>