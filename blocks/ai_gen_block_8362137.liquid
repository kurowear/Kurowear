      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "container_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
