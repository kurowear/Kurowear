{% comment %}

  Delivery Checker Block

  Add this file in: blocks/estimated-delivery-checker.liquid

  Works as a Shopify theme block in Horizon theme

{% endcomment %}


{% liquid

  assign block_id = 'ns-delivery-checker-' | append: block.id

%}


<div

  id="{{ block_id }}"

  class="ns-delivery-checker"

  data-ns-delivery-checker

  {{ block.shopify_attributes }}

>

  {% if block.settings.label != blank or block.settings.heading != blank or block.settings.subheading != blank %}

    <div class="ns-delivery-header">

      {% if block.settings.label != blank %}

        <span class="ns-delivery-label">

          {{ block.settings.label }}

        </span>

      {% endif %}


      {% if block.settings.heading != blank %}

        <div class="ns-delivery-heading">

          {{ block.settings.heading }}

        </div>

      {% endif %}


      {% if block.settings.subheading != blank %}

        <div class="ns-delivery-subheading">

          {{ block.settings.subheading }}

        </div>

      {% endif %}

    </div>

  {% endif %}


  <div class="ns-pincode-form" data-pincode-form>

    <input

      type="tel"

      inputmode="numeric"

      pattern="[0-9]*"

      maxlength="6"

      placeholder="{{ block.settings.placeholder | escape }}"

      autocomplete="postal-code"

      data-pincode-input

    >


    <button type="button" data-check-btn>

      {{ block.settings.button_text }}

    </button>

  </div>


  {% if block.settings.note_text != blank %}

    <p class="ns-pincode-note" data-pincode-note>

      {{ block.settings.note_text }}

    </p>

  {% endif %}


  <p class="ns-pincode-error" data-pincode-error hidden>

    {{ block.settings.error_text }}

  </p>


  <div class="ns-delivery-result" data-delivery-result hidden>

    <div class="ns-checked-pin">

      <span>

        {{ block.settings.delivery_to_text }}

        <span data-display-pin></span>

      </span>


      {% if block.settings.show_tick %}

        <span class="ns-tick">{{ block.settings.tick_text }}</span>

      {% endif %}


      <button type="button" class="ns-change-btn" data-change-btn>

        {{ block.settings.change_text }}

      </button>

    </div>


    <div class="ns-delivery-info">

      {% if block.settings.delivery_icon != blank %}

        <span class="ns-delivery-icon">

          {{ block.settings.delivery_icon }}

        </span>

      {% endif %}


      <span>

        {{ block.settings.estimated_text }}

        <span data-delivery-date></span>

      </span>

    </div>

  </div>

</div>


<style>

  #{{ block_id }},

  #{{ block_id }} * {

    box-sizing: border-box;

  }


  #{{ block_id }} {

    width: 100%;

    margin-top: {{ block.settings.margin_top }}px;

    margin-bottom: {{ block.settings.margin_bottom }}px;

    padding: {{ block.settings.box_padding }}px;

    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};

    border-radius: {{ block.settings.border_radius }}px;

    background: {{ block.settings.box_background }};

    color: {{ block.settings.text_color }};

    font-family: {{ block.settings.font_family }};

    font-weight: {{ block.settings.font_weight }};

  }


  #{{ block_id }} .ns-delivery-header {

    margin-bottom: {{ block.settings.header_gap }}px;

  }


  #{{ block_id }} .ns-delivery-label {

    display: block;

    margin-bottom: 4px;

    color: {{ block.settings.label_color }};

    font-size: {{ block.settings.label_size }}px;

    line-height: 1.2;

    text-transform: {{ block.settings.label_transform }};

    letter-spacing: {{ block.settings.label_spacing }}px;

  }


  #{{ block_id }} .ns-delivery-heading {

    color: {{ block.settings.heading_color }};

    font-size: {{ block.settings.heading_size }}px;

    line-height: 1.35;

  }


  #{{ block_id }} .ns-delivery-subheading {

    margin-top: 5px;

    color: {{ block.settings.subheading_color }};

    font-size: {{ block.settings.subheading_size }}px;

    line-height: 1.4;

  }


  #{{ block_id }} .ns-pincode-form {

    display: flex;

    align-items: stretch;

    width: 100%;

    gap: {{ block.settings.input_button_gap }}px;

    margin-bottom: {{ block.settings.form_gap_bottom }}px;

  }


  #{{ block_id }} .ns-pincode-form input {

    flex: 1;

    width: 100%;

    min-width: 0;

    height: {{ block.settings.input_height }}px;

    padding: 0 {{ block.settings.input_padding_x }}px;

    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};

    border-radius: {{ block.settings.input_radius }}px;

    background: {{ block.settings.input_background }};

    color: {{ block.settings.input_text_color }};

    font-size: {{ block.settings.input_font_size }}px;

    font-family: inherit;

    font-weight: inherit;

    outline: none;

    box-shadow: none;

  }


  #{{ block_id }} .ns-pincode-form input::placeholder {

    color: {{ block.settings.placeholder_color }};

    opacity: 1;

  }


  #{{ block_id }} .ns-pincode-form input:focus {

    border-color: {{ block.settings.input_focus_border }};

    outline: none;

    box-shadow: none;

  }


  #{{ block_id }} .ns-pincode-form button {

    height: {{ block.settings.button_height }}px;

    min-width: {{ block.settings.button_min_width }}px;

    padding: 0 {{ block.settings.button_padding_x }}px;

    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};

    border-radius: {{ block.settings.button_radius }}px;

    background: {{ block.settings.button_background }};

    color: {{ block.settings.button_text_color }};

    font-size: {{ block.settings.button_font_size }}px;

    font-family: inherit;

    font-weight: inherit;

    line-height: 1;

    cursor: pointer;

    white-space: nowrap;

    transition: 0.2s ease;

  }


  #{{ block_id }} .ns-pincode-form button:hover {

    background: {{ block.settings.button_hover_background }};

    border-color: {{ block.settings.button_hover_border_color }};

    color: {{ block.settings.button_hover_text_color }};

  }


  #{{ block_id }} .ns-pincode-note {

    margin: 0 0 {{ block.settings.note_gap_bottom }}px;

    color: {{ block.settings.note_color }};

    font-size: {{ block.settings.note_size }}px;

    line-height: 1.4;

  }


  #{{ block_id }} .ns-pincode-error {

    margin: 0 0 {{ block.settings.error_gap_bottom }}px;

    color: {{ block.settings.error_color }};

    font-size: {{ block.settings.error_size }}px;

    line-height: 1.4;

  }


  #{{ block_id }} .ns-pincode-error[hidden],

  #{{ block_id }} .ns-delivery-result[hidden] {

    display: none !important;

  }


  #{{ block_id }} .ns-checked-pin,

  #{{ block_id }} .ns-delivery-info {

    width: 100%;

    padding: {{ block.settings.result_padding_y }}px {{ block.settings.result_padding_x }}px;

    border: {{ block.settings.result_border_width }}px solid {{ block.settings.result_border_color }};

    border-radius: {{ block.settings.result_radius }}px;

    background: {{ block.settings.result_background }};

    color: {{ block.settings.result_text_color }};

    font-size: {{ block.settings.result_font_size }}px;

    line-height: 1.4;

  }


  #{{ block_id }} .ns-checked-pin {

    display: flex;

    align-items: center;

    gap: 8px;

    margin-bottom: {{ block.settings.result_gap }}px;

  }


  #{{ block_id }} .ns-delivery-info {

    display: flex;

    align-items: center;

    gap: 7px;

  }


  #{{ block_id }} [data-display-pin] {

    color: {{ block.settings.pin_color }};

  }


  #{{ block_id }} [data-delivery-date] {

    color: {{ block.settings.date_color }};

  }


  #{{ block_id }} .ns-tick {

    color: {{ block.settings.tick_color }};

    font-size: {{ block.settings.tick_size }}px;

    line-height: 1;

  }


  #{{ block_id }} .ns-change-btn {

    margin-left: auto;

    padding: 0;

    border: 0;

    background: transparent;

    color: {{ block.settings.change_color }};

    font-size: {{ block.settings.change_size }}px;

    font-family: inherit;

    font-weight: inherit;

    line-height: 1;

    cursor: pointer;

    text-decoration: {% if block.settings.change_underline %}underline{% else %}none{% endif %};

    text-underline-offset: 3px;

  }


  #{{ block_id }} .ns-delivery-icon {

    font-size: {{ block.settings.icon_size }}px;

    line-height: 1;

  }


  @media screen and (max-width: 749px) {

    #{{ block_id }} {

      margin-top: {{ block.settings.mobile_margin_top }}px;

      margin-bottom: {{ block.settings.mobile_margin_bottom }}px;

      padding: {{ block.settings.mobile_box_padding }}px;

      border-radius: {{ block.settings.mobile_border_radius }}px;

    }


    #{{ block_id }} .ns-delivery-label {

      font-size: {{ block.settings.mobile_label_size }}px;

    }


    #{{ block_id }} .ns-delivery-heading {

      font-size: {{ block.settings.mobile_heading_size }}px;

    }


    #{{ block_id }} .ns-delivery-subheading {

      font-size: {{ block.settings.mobile_subheading_size }}px;

    }


    #{{ block_id }} .ns-pincode-form {

      gap: {{ block.settings.mobile_input_button_gap }}px;

    }


    #{{ block_id }} .ns-pincode-form input {

      height: {{ block.settings.mobile_input_height }}px;

      font-size: {{ block.settings.mobile_input_font_size }}px;

    }


    #{{ block_id }} .ns-pincode-form button {

      height: {{ block.settings.mobile_button_height }}px;

      min-width: {{ block.settings.mobile_button_min_width }}px;

      font-size: {{ block.settings.mobile_button_font_size }}px;

    }


    #{{ block_id }} .ns-pincode-note,

    #{{ block_id }} .ns-pincode-error,

    #{{ block_id }} .ns-checked-pin,

    #{{ block_id }} .ns-delivery-info {

      font-size: {{ block.settings.mobile_result_font_size }}px;

    }


    {% if block.settings.mobile_stack %}

      #{{ block_id }} .ns-pincode-form {

        flex-direction: column;

      }


      #{{ block_id }} .ns-pincode-form button {

        width: 100%;

      }

    {% endif %}

  }


  {{ block.settings.custom_css }}

</style>


<script>

  (function () {

    var deliveryBox = document.getElementById('{{ block_id }}');


    if (!deliveryBox || deliveryBox.dataset.loaded === 'true') return;

    deliveryBox.dataset.loaded = 'true';


    var input = deliveryBox.querySelector('[data-pincode-input]');

    var checkBtn = deliveryBox.querySelector('[data-check-btn]');

    var pincodeForm = deliveryBox.querySelector('[data-pincode-form]');

    var resultBox = deliveryBox.querySelector('[data-delivery-result]');

    var note = deliveryBox.querySelector('[data-pincode-note]');

    var error = deliveryBox.querySelector('[data-pincode-error]');

    var displayPin = deliveryBox.querySelector('[data-display-pin]');

    var deliveryDate = deliveryBox.querySelector('[data-delivery-date]');

    var changeBtn = deliveryBox.querySelector('[data-change-btn]');


    var storageKey = 'ns_saved_pincode_{{ block.id }}';


    if (!input || !checkBtn || !pincodeForm || !resultBox) return;


    function cleanPincode(value) {

      return String(value || '').replace(/\D/g, '').slice(0, 6);

    }


    function getPincodeZone(pin) {

      var p = parseInt(pin, 10);


      if (

        (p >= 110001 && p <= 110096) ||

        (p >= 201001 && p <= 201310) ||

        (p >= 122001 && p <= 122508) ||

        (p >= 124001 && p <= 124507) ||

        (p >= 131001 && p <= 131402) ||

        (p >= 121001 && p <= 121106) ||

        (p >= 245001 && p <= 245412)

      ) {

        return {{ block.settings.zone_1_days }};

      }


      if (

        (p >= 200001 && p <= 285205) ||

        (p >= 125001 && p <= 136156) ||

        (p >= 140001 && p <= 160059) ||

        (p >= 301001 && p <= 345034) ||

        (p >= 246001 && p <= 263680) ||

        (p >= 170001 && p <= 177213)

      ) {

        return {{ block.settings.zone_2_days }};

      }


      if (

        (p >= 450001 && p <= 488776) ||

        (p >= 800001 && p <= 855117) ||

        (p >= 360001 && p <= 396590) ||

        (p >= 400001 && p <= 445402) ||

        (p >= 490001 && p <= 497778) ||

        (p >= 700001 && p <= 743710)

      ) {

        return {{ block.settings.zone_3_days }};

      }


      return {{ block.settings.default_delivery_days }};

    }


    function getDeliveryDate(days) {

      var date = new Date();

      date.setDate(date.getDate() + Number(days || 0));


      return date.toLocaleDateString('en-IN', {

        weekday: {% if block.settings.show_weekday %}'short'{% else %}undefined{% endif %},

        month: 'short',

        day: 'numeric'

      });

    }


    function showError() {

      if (error) error.hidden = false;

    }


    function hideError() {

      if (error) error.hidden = true;

    }


    function showResult(pin) {

      var days = getPincodeZone(pin);


      pincodeForm.style.display = 'none';


      if (note) note.style.display = 'none';

      if (displayPin) displayPin.textContent = pin;

      if (deliveryDate) deliveryDate.textContent = getDeliveryDate(days);


      resultBox.hidden = false;

      hideError();


      {% if block.settings.remember_pincode %}

        try {

          localStorage.setItem(storageKey, pin);

        } catch (e) {}

      {% endif %}

    }


    function checkPincode() {

      var pin = cleanPincode(input.value);

      input.value = pin;


      if (pin.length !== 6) {

        showError();

        return;

      }


      showResult(pin);

    }


    function changePincode() {

      pincodeForm.style.display = 'flex';


      if (note) note.style.display = '';

      if (input) input.value = '';


      resultBox.hidden = true;

      hideError();


      {% if block.settings.remember_pincode %}

        try {

          localStorage.removeItem(storageKey);

        } catch (e) {}

      {% endif %}


      setTimeout(function () {

        input.focus();

      }, 50);

    }


    input.addEventListener('input', function () {

      input.value = cleanPincode(input.value);

      hideError();

    });


    input.addEventListener('keydown', function (event) {

      if (event.key === 'Enter') {

        event.preventDefault();

        checkPincode();

      }

    });


    checkBtn.addEventListener('click', checkPincode);


    if (changeBtn) {

      changeBtn.addEventListener('click', changePincode);

    }


    {% if block.settings.remember_pincode %}

      try {

        var savedPin = localStorage.getItem(storageKey);


        if (savedPin && cleanPincode(savedPin).length === 6) {

          input.value = cleanPincode(savedPin);

          showResult(cleanPincode(savedPin));

        }

      } catch (e) {}

    {% endif %}

  })();

</script>


{% schema %}

